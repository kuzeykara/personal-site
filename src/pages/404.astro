---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — kuzeykara" description="Page not found.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 pt-32 pb-20 text-center">
    <h1 class="text-6xl md:text-7xl font-bold text-accent mb-4">404</h1>
    <p class="text-text-muted text-lg mb-8">Page not found.</p>
    <a
      href="/"
      class="font-mono text-sm px-5 py-2.5 border border-accent text-accent rounded hover:bg-accent hover:text-bg transition-colors duration-200 no-underline"
    >
      Go home
    </a>
  </section>
</Layout>
