---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import BlogPostCard from "../../components/BlogPostCard.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Blog — kuzeykara" description="Cybersecurity research, write-ups, and notes.">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 pt-16 pb-20">
    <h1 class="text-3xl md:text-4xl mb-2">Blog</h1>
    <p class="text-text-muted mb-8">
      Research, write-ups, notes, and updates.
    </p>
    {posts.length > 0 ? (
      <div class="border-t border-border">
        {posts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            slug={post.id}
          />
        ))}
      </div>
    ) : (
      <p class="text-text-muted font-mono text-sm">No posts yet. Check back soon.</p>
    )}
  </section>
</Layout>
