---
const pathname = Astro.url.pathname;
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
];

const socialLinks = [
  {
    href: "https://github.com/kuzeykara/",
    label: "GitHub",
    icon: "github",
  },
  {
    href: "https://www.linkedin.com/in/kuzey-kara/",
    label: "LinkedIn",
    icon: "linkedin",
  },
  {
    href: "https://profile.hackthebox.com/profile/019cb7be-cc1f-7272-a552-2d70cd686087/",
    label: "Hack The Box",
    icon: "htb",
  },
  {
    href: "mailto:kuzeykara@protonmail.com",
    label: "Email",
    icon: "email",
  },
];

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg-nav backdrop-blur-md border-b border-border">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14">
    <a href="/" class="font-mono font-bold text-lg text-text hover:text-accent no-underline tracking-tight">
      ~/kuzeykara
    </a>

    <div class="hidden md:flex items-center gap-6">
      <ul class="flex items-center gap-6 list-none m-0 p-0">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                "font-mono text-sm no-underline transition-colors duration-200",
                isActive(href) ? "text-accent" : "text-text-muted hover:text-text",
              ]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>

      <span class="w-px h-4 bg-border"></span>

      <div class="flex items-center gap-3">
        {socialLinks.map(({ href, label, icon }) => (
          <a
            href={href}
            target={href.startsWith("http") ? "_blank" : undefined}
            rel={href.startsWith("http") ? "noopener noreferrer" : undefined}
            class="text-text-muted hover:text-accent transition-colors duration-200"
            aria-label={label}
          >
            {icon === "github" && (
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z" clip-rule="evenodd"/>
              </svg>
            )}
            {icon === "linkedin" && (
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286ZM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065Zm1.782 13.019H3.555V9h3.564v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z"/>
              </svg>
            )}
            {icon === "htb" && (
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M11.996 0a1.12 1.12 0 0 0-.574.16L2.134 5.486a1.13 1.13 0 0 0-.576.984v10.054a1.13 1.13 0 0 0 .576.984l9.288 5.326a1.12 1.12 0 0 0 1.148 0l9.288-5.326a1.13 1.13 0 0 0 .576-.984V6.47a1.13 1.13 0 0 0-.576-.984L12.57.16a1.12 1.12 0 0 0-.574-.16Zm-.04 3.148c.186 0 .373.048.537.144l5.186 2.975a1.075 1.075 0 0 1 0 1.862l-5.186 2.975a1.075 1.075 0 0 1-1.074 0L6.233 8.13a1.075 1.075 0 0 1 0-1.862l5.186-2.975a1.07 1.07 0 0 1 .537-.144Zm-6.2 6.072c.186 0 .373.048.537.144l5.186 2.975a1.075 1.075 0 0 1 .537.931v5.95a1.075 1.075 0 0 1-1.612.931L5.22 17.176a1.075 1.075 0 0 1-.538-.931v-5.95c0-.384.205-.74.538-.931a1.07 1.07 0 0 1 .537-.144Zm12.4 0c.187 0 .373.048.537.144.333.191.538.547.538.931v5.95c0 .384-.205.74-.538.931l-5.186 2.975a1.075 1.075 0 0 1-1.612-.931v-5.95c0-.384.205-.74.537-.931l5.186-2.975a1.07 1.07 0 0 1 .537-.144Z"/>
              </svg>
            )}
            {icon === "email" && (
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            )}
          </a>
        ))}
      </div>
    </div>

    <button
      id="menu-toggle"
      class="md:hidden flex flex-col justify-center items-center w-8 h-8 gap-1.5 bg-transparent border-none cursor-pointer"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="menu-bar block w-5 h-0.5 bg-text transition-all duration-200"></span>
      <span class="menu-bar block w-5 h-0.5 bg-text transition-all duration-200"></span>
      <span class="menu-bar block w-5 h-0.5 bg-text transition-all duration-200"></span>
    </button>
  </div>

  <div id="mobile-menu" class="md:hidden hidden border-t border-border bg-bg-nav backdrop-blur-md">
    <ul class="flex flex-col list-none m-0 p-0 py-2">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              "block px-6 py-2.5 font-mono text-sm no-underline transition-colors duration-200",
              isActive(href) ? "text-accent" : "text-text-muted hover:text-text",
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
    <div class="flex items-center gap-4 px-6 py-3 border-t border-border">
      {socialLinks.map(({ href, label, icon }) => (
        <a
          href={href}
          target={href.startsWith("http") ? "_blank" : undefined}
          rel={href.startsWith("http") ? "noopener noreferrer" : undefined}
          class="text-text-muted hover:text-accent transition-colors duration-200"
          aria-label={label}
        >
          {icon === "github" && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z" clip-rule="evenodd"/>
            </svg>
          )}
          {icon === "linkedin" && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286ZM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065Zm1.782 13.019H3.555V9h3.564v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z"/>
            </svg>
          )}
          {icon === "htb" && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M11.996 0a1.12 1.12 0 0 0-.574.16L2.134 5.486a1.13 1.13 0 0 0-.576.984v10.054a1.13 1.13 0 0 0 .576.984l9.288 5.326a1.12 1.12 0 0 0 1.148 0l9.288-5.326a1.13 1.13 0 0 0 .576-.984V6.47a1.13 1.13 0 0 0-.576-.984L12.57.16a1.12 1.12 0 0 0-.574-.16Zm-.04 3.148c.186 0 .373.048.537.144l5.186 2.975a1.075 1.075 0 0 1 0 1.862l-5.186 2.975a1.075 1.075 0 0 1-1.074 0L6.233 8.13a1.075 1.075 0 0 1 0-1.862l5.186-2.975a1.07 1.07 0 0 1 .537-.144Zm-6.2 6.072c.186 0 .373.048.537.144l5.186 2.975a1.075 1.075 0 0 1 .537.931v5.95a1.075 1.075 0 0 1-1.612.931L5.22 17.176a1.075 1.075 0 0 1-.538-.931v-5.95c0-.384.205-.74.538-.931a1.07 1.07 0 0 1 .537-.144Zm12.4 0c.187 0 .373.048.537.144.333.191.538.547.538.931v5.95c0 .384-.205.74-.538.931l-5.186 2.975a1.075 1.075 0 0 1-1.612-.931v-5.95c0-.384.205-.74.537-.931l5.186-2.975a1.07 1.07 0 0 1 .537-.144Z"/>
            </svg>
          )}
          {icon === "email" && (
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          )}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      menu.classList.toggle("hidden");
    });
  }
</script>
